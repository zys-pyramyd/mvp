# ==========================================
# PYRAMYD - BACKEND ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in the values for local development.
# In production (Render/Heroku/Railway), paste these exact keys into your Environment Settings.

# -----------------
# Core Security
# -----------------
# Required for signing auth tokens. Generate a secure random string.
JWT_SECRET=your_super_secret_jwt_key_here
PORT=8000
# Used to encrypt sensitive data (like BVN). Must be a valid Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# -----------------
# Admin Verification Configuration
# -----------------
# -----------------
# Admin Bootstrap (One-Time Setup)
# -----------------
# These are used by POST /api/setup/create-admin to bootstrap your first admin account.
# No shell access needed — ideal for Render free tier.
#
# HOW IT WORKS:
#   1. Set ALL five variables below in your Render dashboard environment settings.
#   2. Deploy the app.
#   3. Make a single POST request (from Postman, browser, or curl):
#
#      POST https://your-app.onrender.com/api/setup/create-admin
#      Content-Type: application/json
#      { "setup_secret": "the_value_of_ADMIN_SETUP_SECRET" }
#
#   4. That's it. Credentials come from Render env vars — nothing sensitive in the request body.
#   5. The endpoint self-locks after first use (returns 409 on any future call).
#
# ADMIN_SETUP_SECRET — A long, random string only you know. Guards the endpoint.
#                      Example: openssl rand -hex 32
ADMIN_SETUP_SECRET=pick_a_long_random_string_only_you_know

# Admin account details — set these before triggering the endpoint
ADMIN_FIRST_NAME=Your
ADMIN_LAST_NAME=Name
ADMIN_EMAIL=admin@pyramydhub.com
ADMIN_PASSWORD=YourStrongPass1

# The following is only needed if you also use the JWT-protected
# POST /api/admin/users/create endpoint (requires existing admin JWT) to add more admins.
# ADMIN_CREATION_SECRET=your_admin_secret_phrase


# -----------------
# Database (MongoDB Atlas)
# -----------------
MONGO_USERNAME=pyramyd_db_user
MONGO_PASSWORD=your_secure_db_password
# E.g., cluster0.abcd.mongodb.net
MONGO_CLUSTER=your_mongodb_cluster_url
MONGO_DB_NAME=pyramyd
MONGO_AUTH_SOURCE=admin

# -----------------
# Payments (Paystack)
# -----------------
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# -----------------
# Email Notifications (Zoho ZeptoMail)
# -----------------
# Note: Registration will still succeed even if this is missing due to our graceful exception wrappers, but users won't get emails.
ZEPTOMAIL_TOKEN=your_zoho_zeptomail_send_token
ZEPTOMAIL_FROM_ADDRESS=noreply@pyramydhub.com

# -----------------
# Cloud Storage (Cloudflare R2 for Images/Docs)
# -----------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# -----------------
# Global Configuration
# -----------------
# Controls which frontend domains are allowed to hit this backend API.
# Leave empty to default to localhost and pyramydhub.com, or explicitly define:
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
