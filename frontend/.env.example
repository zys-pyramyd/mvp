# ==========================================
# PYRAMYD - FRONTEND ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in the values for local development.
# In production (e.g., Vercel), paste these keys into your project's Environment Variables settings.

# -----------------
# Backend API Integration
# -----------------
# The fully qualified URL of your deployed FastAPI backend (e.g., Render, Heroku, DigitalOcean)
# DO NOT include a trailing slash!
# Example: https://pyramyd-backend.onrender.com
REACT_APP_BACKEND_URL=http://localhost:8001

# -----------------
# Stripe / Payment Integration (if applicable on UI side)
# -----------------
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# -----------------
# Maps & Geolocation
# -----------------
# If you are displaying Leaflet or Google Maps for deliveries
REACT_APP_MAPS_API_KEY=your_maps_api_key
